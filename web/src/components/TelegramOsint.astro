---
const { telegramData = [] } = Astro.props;

const items = Array.isArray(telegramData) ? telegramData : [];
---

<section class="group relative overflow-hidden rounded-3xl bg-black/40 border border-white/[0.05] p-6 sm:p-8 backdrop-blur-2xl shadow-[0_8px_32px_rgba(0,0,0,0.5)] transition-all duration-700 hover:border-white/[0.1] hover:bg-black/50 mx-auto w-full max-w-[80rem]">
  <div class="absolute inset-0 bg-gradient-to-br from-white/[0.03] via-transparent to-white/[0.01] opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
  
  <div class="mb-6 flex items-end justify-between border-b border-white/[0.08] pb-5">
    <div class="flex flex-col">
      <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-400 font-bold mb-1.5 flex items-center gap-2">
        <svg class="w-3 h-3 text-zinc-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        OSINT Network
      </p>
      <h2 class="text-3xl font-normal tracking-wide text-zinc-100 intel-title-font">
        Telegram Intel
      </h2>
    </div>
    <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.03] border border-white/[0.05]">
      <span class="relative flex h-1.5 w-1.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-zinc-300"></span>
      </span>
      <span class="text-[10px] uppercase font-bold tracking-[0.2em] text-zinc-400 mt-0.5">{items.length} signals</span>
    </div>
  </div>

  <div class="max-h-[36rem] overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-white/[0.1] scrollbar-track-transparent hover:scrollbar-thumb-white/[0.2]">
    <div class="flex flex-col gap-3">
      {
        items.map((item) => (
          <article class="group/item relative border border-white/[0.05] bg-black/40 p-5 rounded-2xl transition-all duration-300 hover:bg-white/[0.03] hover:border-white/[0.1] hover:shadow-lg">
            <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-zinc-500/0 transition-colors duration-300 group-hover/item:bg-zinc-300/70 rounded-l-2xl"></div>
            <p class="text-base font-medium text-zinc-100 group-hover/item:text-white transition-colors tracking-wide">{item?.title ?? 'Untitled Signal'}</p>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400 font-light group-hover/item:text-zinc-300 transition-colors">{item?.desc ?? 'No descriptor data attached.'}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
