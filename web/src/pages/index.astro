---
import Layout from '../layouts/Layout.astro';
import NewsMarquee from '../components/marquee.jsx';
import StabilityPanels from '../components/StabilityPanels.jsx';
import BreakingNewsFeed from '../components/BreakingNewsFeed.jsx';
import IndiaMap from '../components/IndiaMap.jsx';
import TelegramOsint from '../components/TelegramOsint.astro';

const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL || 'http://192.168.0.99:8006';

async function safeJson(path: string) {
	try {
		const response = await fetch(`${BASE_URL}${path}`);
		if (!response.ok) return [];
		return await response.json();
	} catch {
		return [];
	}
}

const marqueeData = await safeJson('/v1/marquee');
const indiaData = await safeJson('/v1/stability/India');
const worldData = await safeJson('/v1/stability/World');
const breakingNewsData = await safeJson('/v1/breaking-news');
const telegramData = await safeJson('/v1/telegram');
const coordinatesData = await safeJson('/v1/coordinates');

function normalizeCoordinateItem(item: unknown) {
	if (Array.isArray(item) && item.length >= 2) {
		const [latitude, longitude, comment = ''] = item;
		if (typeof latitude === 'number' && typeof longitude === 'number') {
			return {
				position: [latitude, longitude],
				comment: typeof comment === 'string' ? comment : '',
			};
		}
	}

	if (item && typeof item === 'object') {
		const latitude = 'latitude' in item ? item.latitude : undefined;
		const longitude = 'longitude' in item ? item.longitude : undefined;
		const comment =
			('comment' in item && typeof item.comment === 'string' && item.comment) ||
			('desc' in item && typeof item.desc === 'string' && item.desc) ||
			'';

		if (typeof latitude === 'number' && typeof longitude === 'number') {
			return {
				position: [latitude, longitude],
				comment,
			};
		}
	}

	return null;
}

let coordinatesDataFormatted = {
	conflict: [],
	weather: [],
	concern: [],
};
if (coordinatesData && typeof coordinatesData === 'object') {
	coordinatesDataFormatted = {
		conflict: Array.isArray(coordinatesData.conflict)
			? coordinatesData.conflict.map(normalizeCoordinateItem).filter(Boolean)
			: [],
		weather: Array.isArray(coordinatesData.weather)
			? coordinatesData.weather.map(normalizeCoordinateItem).filter(Boolean)
			: [],
		concern: Array.isArray(coordinatesData.concern)
			? coordinatesData.concern.map(normalizeCoordinateItem).filter(Boolean)
			: [],
	};
}
---

<Layout title="INTEL">
	<main class="relative min-h-screen bg-[#07090d] px-4 pt-4 pb-8 sm:px-6 sm:pt-6">
		<div class="pointer-events-none absolute left-1/2 top-0 -translate-x-1/2">
			<div class="h-[16rem] w-[48rem] bg-zinc-500/10 blur-[120px]"></div>
		</div>

		<div class="relative mx-auto w-full max-w-[82rem] p-4 sm:p-6">
			<h1 class="text-center text-6xl font-extrabold tracking-[0.15em] text-zinc-100 sm:text-8xl">
				INTEL
			</h1>

			<div class="mx-auto mt-5 w-full max-w-[80rem]">
				<NewsMarquee newsItems={marqueeData} client:only="react" />
			</div>
			<IndiaMap
				conflict={coordinatesDataFormatted.conflict}
				weather={coordinatesDataFormatted.weather}
				concern={coordinatesDataFormatted.concern}
				client:only="react"
			/>

			<section class="mx-auto mt-8 grid w-full max-w-[80rem] gap-6 md:grid-cols-2 xl:gap-8">
				<StabilityPanels label="India" panelData={indiaData} client:only="react" />
				<StabilityPanels label="World" panelData={worldData} client:only="react" />
			</section>

			<BreakingNewsFeed newsData={breakingNewsData} client:only="react" />
			<TelegramOsint telegramData={telegramData} />
		</div>
	</main>
</Layout>
